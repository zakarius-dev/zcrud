# ------------------------------------------------------------------
# Dart / Flutter
# ------------------------------------------------------------------
.dart_tool/
.packages
.pub-cache/
.pub/
build/
**/build/
.flutter-plugins
.flutter-plugins-dependencies
**/doc/api/
.fvm/

# Fichiers de lock : conservés pour les apps, ignorés pour les packages/lib.
# Monorepo de packages -> on ignore par défaut (décommenter si besoin de figer).
# pubspec.lock

# Overrides générés par melos / pub workspaces
pubspec_overrides.yaml
**/pubspec_overrides.yaml
.melos_tool/

# ------------------------------------------------------------------
# Génération de code (build_runner) — NON suivi par git (régénérable)
# ------------------------------------------------------------------
# À régénérer après clone/pull ou après modif d'une annotation
# (@ZcrudModel/@JsonSerializable/@riverpod). La CI exécute le codegen
# avant analyze/test/build.
*.g.dart
*.freezed.dart
*.gr.dart
*.mocks.dart

# EXCEPTION distribution git-privée : `zcrud_flashcard` utilise du codegen
# (`part '*.g.dart'`) et est consommé en dépendance **git** → son code généré
# DOIT être versionné (un consommateur clone l'arbre git au tag et ne régénère
# PAS le code d'une dépendance). Les autres packages restent gitignorés.
!packages/zcrud_flashcard/lib/**/*.g.dart

